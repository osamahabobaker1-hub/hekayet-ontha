generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  imageUrl    String
  category    String   @default("عام") // تأكد من إضافة هذا السطر
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Order {
  id              Int         @id @default(autoincrement())
  customerName    String
  customerEmail   String
  customerPhone   String
  address         String
  totalAmount     Float
  status          String      @default("قيد التنفيذ")
  items           OrderItem[]
  createdAt       DateTime    @default(now())
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  productName String
  price     Float
  quantity  Int
}